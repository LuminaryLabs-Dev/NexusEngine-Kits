    "./domain-progression": "./domains/progression/index.js",
    "./domain-hazard-combat": "./domains/hazard-combat/index.js",
    "./domain-economy-resources": "./domains/economy-resources/index.js",
    "./domain-building": "./domains/building/index.js",
    "./domain-camera-feedback": "./domains/camera-feedback/index.js",
    "./domain-render-descriptors": "./domains/render-descriptors/index.js",
    "./domain-aerial": "./domains/aerial/index.js",
    "./domain-rpg-social": "./domains/rpg-social/index.js",
