{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NexusEngine Domain Manifest",
  "type": "object",
  "required": ["schemaVersion", "id", "label", "status", "domainPath", "entry", "kits"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": "nexusengine.domain-manifest.v1" },
    "status": { "type": "string", "minLength": 1 },
    "domainPath": { "type": "string", "pattern": "^n:" },
    "entry": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "kind": { "type": "string" },
    "kits": { "type": "array", "items": { "type": "string" } },
    "exports": { "type": "object" }
  },
  "additionalProperties": true
}
