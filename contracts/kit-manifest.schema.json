{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NexusEngine Kit Manifest",
  "type": "object",
  "required": ["schemaVersion", "id", "version", "status", "domain", "domainPath", "apiName", "kind", "factory", "entry", "module", "provides", "requires", "promotion"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": "nexusengine.kit-manifest.v1" },
    "version": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "kind": { "type": "string" },
    "domainPath": { "type": "string", "pattern": "^n:" },
    "apiName": { "type": "string", "minLength": 1 },
    "factory": { "type": "string", "minLength": 1 },
    "entry": { "type": "string", "minLength": 1 },
    "provides": { "type": "array", "items": { "type": "string" } },
    "requires": { "type": "array", "items": { "type": "string" } },
    "module": { "type": "object" },
    "promotion": { "type": "object" },
    "cdn": { "type": "object" },
    "source": { "type": "object" }
  },
  "additionalProperties": true
}
