{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NexusRealtime Bundle Manifest",
  "type": "object",
  "required": ["id", "domains"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "domains": { "type": "array", "items": { "type": "string" } },
    "exports": { "type": "object" }
  },
  "additionalProperties": true
}
